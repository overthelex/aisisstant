def _bucket_breakdown_text(buckets: dict) -> str:
    parts = []
    for b in _BUCKET_ORDER:
        secs = buckets.get(b, 0.0)
        if secs > 0:
            parts.append(f"{_BUCKET_LABELS.get(b, b)} {_fmt_duration(secs)}")
    return " · ".join(parts)


def _make_group_row(group: dict, total_seconds: float) -> Gtk.Widget:
    name = group.get("name", "?")
    secs = group.get("seconds", 0.0) or 0.0
    buckets = group.get("buckets", {}) or {}
    dominant = group.get("dominant_bucket", "other")
    is_known = group.get("is_known", True)
    frac = (secs / total_seconds) if total_seconds > 0 else 0.0

    row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=14)
    row.set_margin_start(14)
    row.set_margin_end(14)
    row.set_margin_top(12)
    row.set_margin_bottom(12)

    icon_bg = Gtk.Box(halign=Gtk.Align.CENTER, valign=Gtk.Align.CENTER)
    icon_bg.add_css_class("xs-bucket-icon")
    icon_bg.add_css_class(f"xs-bucket-{dominant}")
    icon_name = (
        "folder-symbolic" if is_known
        else "question-round-symbolic"
    )
    icon = Gtk.Image.new_from_icon_name(icon_name)
    icon.set_pixel_size(18)
    icon_bg.append(icon)
    row.append(icon_bg)

    middle = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
    middle.set_hexpand(True)
    middle.set_valign(Gtk.Align.CENTER)

    top = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    name_label = Gtk.Label(xalign=0, hexpand=True)
    name_label.set_ellipsize(Pango.EllipsizeMode.END)
    name_label.set_text(name)
    name_label.add_css_class("xs-project-name")
    top.append(name_label)

    dur_label = Gtk.Label(label=_fmt_duration(secs), xalign=1)
    dur_label.add_css_class("xs-project-duration")
    top.append(dur_label)
    middle.append(top)

    sub_text = _bucket_breakdown_text(buckets)
    if not sub_text:
        sub_text = f"{frac * 100:.1f}% of total"
    else:
        sub_text = f"{sub_text} · {frac * 100:.1f}%"
    sub_label = Gtk.Label(xalign=0, label=sub_text)
    sub_label.set_ellipsize(Pango.EllipsizeMode.END)
    sub_label.add_css_class("xs-project-sub")
    middle.append(sub_label)

    bar = MiniBar()
    bar.set_data(
        _BUCKET_COLORS.get(dominant, _BUCKET_COLORS["other"]), frac
    )
    bar.set_margin_top(4)
    middle.append(bar)

    row.append(middle)
    return row


