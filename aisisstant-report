        self._list_box.add_css_class("boxed-list")
        body.append(self._list_box)

        self._status_label = Gtk.Label(xalign=0)
        self._status_label.add_css_class("dim-label")
        self._status_label.set_margin_top(8)
        self._status_label.set_margin_start(6)
        body.append(self._status_label)

        self._reload(force=True)
        GLib.timeout_add_seconds(_UI_POLL_SECONDS, self._on_tick)

    def _on_range_changed(self, *_):
        idx = self._range_dropdown.get_selected()
        if 0 <= idx < len(self._range_keys):
            self._current_range_key = self._range_keys[idx]
            self._render()

    def _on_group_toggled(self) -> None:
        new_mode = "project" if self._project_btn.get_active() else "activity"
        if new_mode == self._group_mode:
            return
        self._group_mode = new_mode
        self._render()

    def _on_tick(self) -> bool:
        self._reload(force=False)
        if self._cached:
            self._set_status()
        return True

    def _reload(self, force: bool) -> None:
        try:
            st = self._cache_path.stat()
        except FileNotFoundError:
            if force or self._cached is None:
                self._clear_list()
                self._clear_legend()
                self._status_label.set_text(
                    f"No snapshot yet at {self._cache_path}. "
                    "Is the aisisstant service running?"
                )
                self._total_label.set_text("—")
                self._hero_sub.set_text("")
                self._stacked_bar.set_segments([])
            return
        except Exception as e:  # noqa: BLE001
            self._clear_list()
            self._status_label.set_text(f"Cache error: {e}")
            return

        if not force and st.st_mtime <= self._last_mtime:
            return

        try:
            with open(self._cache_path, "r", encoding="utf-8") as f:
                self._cached = json.load(f)
            self._last_mtime = st.st_mtime
        except Exception as e:  # noqa: BLE001
            self._status_label.set_text(f"Cannot parse snapshot: {e}")
            return

        idx = self._range_dropdown.get_selected()
        if 0 <= idx < len(self._range_keys):
            self._current_range_key = self._range_keys[idx]
        self._render()

    def _clear_list(self) -> None:
        child = self._list_box.get_first_child()
        while child is not None:
            nxt = child.get_next_sibling()
            self._list_box.remove(child)
            child = nxt

    def _clear_legend(self) -> None:
        child = self._legend.get_first_child()
        while child is not None:
            nxt = child.get_next_sibling()
            self._legend.remove(child)
            child = nxt

    def _set_status(self) -> None:
        if not self._cached:
            return
        gen_rel = _fmt_relative(self._cached.get("generated_at", ""))
        self._status_label.set_text(f"Snapshot refreshed {gen_rel}")

    def _render(self) -> None:
        self._clear_list()
        self._clear_legend()
        if not self._cached:
            return

        data = self._cached.get("ranges", {}).get(self._current_range_key)
        range_title = _RANGE_LABELS.get(
            self._current_range_key, self._current_range_key
        )
        self._range_label.set_text(range_title.upper())

        if not data:
            self._total_label.set_text("—")
            self._hero_sub.set_text("No data for this range.")
            self._stacked_bar.set_segments([])
            return

        total = data.get("total_seconds", 0.0) or 0.0
        samples = data.get("sample_count", 0)
        projects = data.get("projects", [])

        self._total_label.set_text(_fmt_big_duration(total))

        per_bucket: dict[str, float] = {}
        for p in projects:
            b = p.get("bucket", "other")
            per_bucket[b] = per_bucket.get(b, 0.0) + (
                p.get("seconds", 0.0) or 0.0
            )

        segments = []
        for b in _BUCKET_ORDER:
            if per_bucket.get(b, 0.0) > 0:
                segments.append(
                    (_BUCKET_COLORS.get(b, _BUCKET_COLORS["other"]),
                     per_bucket[b])
                )
        self._stacked_bar.set_segments(segments)

        for b in _BUCKET_ORDER:
            if per_bucket.get(b, 0.0) > 0:
                self._legend.append(_make_legend_item(b, per_bucket[b]))

        self._set_status()

        if self._group_mode == "project":
            groups, unclassified = group_projects(
                projects, self._known_projects
            )
            known_count = sum(1 for g in groups if g.get("is_known"))
            summary = (
                f"{known_count} projects · {samples} samples"
            )
            if unclassified > 0 and total > 0:
                pct = unclassified / total * 100
                summary += (
                    f" · {_fmt_duration(unclassified)} unclassified "
                    f"({pct:.0f}%)"
                )
            self._hero_sub.set_text(summary)
            self._render_groups(groups, total)
        else:
            self._hero_sub.set_text(
                f"{len(projects)} entries · {samples} samples"
            )
            self._render_activities(projects, total)

    def _render_activities(self, projects: list[dict], total: float) -> None:
        if not projects:
            self._list_box.append(self._empty_row(
                "No activity recorded in this range."
            ))
            return
        for proj in projects:
            lbr = Gtk.ListBoxRow()
            lbr.set_selectable(False)
            lbr.set_activatable(False)
            lbr.set_child(_make_project_row(proj, total))
            self._list_box.append(lbr)

    def _render_groups(self, groups: list[dict], total: float) -> None:
        if not groups:
            self._list_box.append(self._empty_row(
                "No project activity matched in this range."
            ))
            return
        for g in groups:
            lbr = Gtk.ListBoxRow()
            lbr.set_selectable(False)
            lbr.set_activatable(False)
            lbr.set_child(_make_group_row(g, total))
            self._list_box.append(lbr)

    def _empty_row(self, text: str) -> Gtk.ListBoxRow:
        row = Gtk.ListBoxRow()
        row.set_selectable(False)
        label = Gtk.Label(label=text, xalign=0)
        label.set_margin_start(16)
        label.set_margin_end(16)
        label.set_margin_top(18)
        label.set_margin_bottom(18)
        label.add_css_class("dim-label")
        row.set_child(label)
        return row


class ReportApp(Adw.Application):
    def __init__(self):
        super().__init__(application_id=APP_ID)
        self.connect("startup", self._on_startup)

    def _on_startup(self, *_):
        css = Gtk.CssProvider()
        text = _build_css()
        try:
            css.load_from_string(text)
        except AttributeError:
            css.load_from_data(text.encode("utf-8"))
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(),
            css,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

    def do_activate(self):
        win = self.props.active_window
        if win is None:
            win = ReportWindow(self)
        win.present()


def main() -> int:
    app = ReportApp()
    return app.run(sys.argv)


if __name__ == "__main__":
    sys.exit(main())
