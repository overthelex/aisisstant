def _build_css() -> str:
    parts = [_CSS_BASE]
    for bucket, (r, g, b) in _BUCKET_COLORS.items():
        parts.append(
            f".xs-bucket-{bucket} {{ background-color: rgb({r},{g},{b}); }}"
        )
        parts.append(
            f".xs-dot-{bucket} {{ background-color: rgb({r},{g},{b}); }}"
        )
    return "\n".join(parts)


def _fmt_big_duration(seconds: float) -> str:
    s = int(round(seconds))
    if s < 60:
        return f"{s}s"
    h, rem = divmod(s, 3600)
    m, _ = divmod(rem, 60)
    if h:
        return f"{h}h {m:d}m"
    return f"{m}m"


def _fmt_duration(seconds: float) -> str:
    s = int(round(seconds))
    if s < 60:
        return f"{s}s"
    m, s = divmod(s, 60)
    if m < 60:
        return f"{m}m {s:02d}s"
    h, m = divmod(m, 60)
    return f"{h}h {m:02d}m"


def _fmt_relative(ts_iso: str) -> str:
    try:
        t = datetime.fromisoformat(ts_iso)
    except Exception:
        return ts_iso
    delta = datetime.now(t.tzinfo) - t
    secs = int(delta.total_seconds())
    if secs < 2:
        return "just now"
    if secs < 60:
        return f"{secs}s ago"
    m, s = divmod(secs, 60)
    if m < 60:
        return f"{m}m ago"
    return f"{m // 60}h {m % 60:02d}m ago"


# ---------------------------------------------------------------------------
# Project grouping
# ---------------------------------------------------------------------------

# Signal tokens that look plausible as project names but are almost never
# the actual project the user is working on. We ignore these during matching.
_PROJECT_STOPWORDS = {
    "src", "repos", "code", "work", "projects", "documents", "home",
    "bin", "tmp", "local", "desktop", "downloads", "public",
    "terminal", "browser", "editor", "other",
    "aisisstant-stats", "aisisstant-report", "aisisstant-setup",
}

_PROJECT_CONFIG_ENV = "AISISSTANT_PROJECTS"
_PROJECT_CONFIG_PATHS = [
    Path.home() / ".config" / "aisisstant" / "projects.json",
]

_PROJECT_TOKEN_RE = re.compile(r"[A-Za-z0-9][A-Za-z0-9._-]{2,}")


def _normalize_token(tok: str) -> str:
    return tok.strip().lower().replace("_", "-")


def discover_known_projects() -> list[str]:
    """Build a canonical project list.

    Priority: explicit config (file or env) → immediate git-repo subdirs of
    $HOME. Dedupes case-insensitively while preserving the prettiest form
    we saw (typically the on-disk directory name).
    """
    seen: dict[str, str] = {}

    def _add(name: str):
        key = _normalize_token(name)
        if not key or key in _PROJECT_STOPWORDS:
            return
        if key in seen:
            # Prefer the shorter (less noisy) variant as canonical.
            if len(name) < len(seen[key]):
                seen[key] = name
            return
        seen[key] = name

    env = os.environ.get(_PROJECT_CONFIG_ENV)
    if env:
        for item in env.split(":"):
            _add(item)

    for cfg_path in _PROJECT_CONFIG_PATHS:
        try:
            with open(cfg_path, "r", encoding="utf-8") as f:
                data = json.load(f)
        except (OSError, ValueError):
            continue
        if isinstance(data, list):
            for item in data:
                if isinstance(item, str):
                    _add(item)
        elif isinstance(data, dict) and isinstance(data.get("projects"), list):
            for item in data["projects"]:
                if isinstance(item, str):
                    _add(item)

    try:
        for entry in Path.home().iterdir():
            try:
                if entry.is_dir() and (entry / ".git").exists():
                    _add(entry.name)
            except OSError:
                continue
    except OSError:
        pass

    # Order: longest keys first so substring matches prefer the
    # most specific project (e.g. "secondlayer-core" before "secondlayer").
    return [seen[k] for k in sorted(seen, key=lambda k: (-len(k), k))]


def _best_project_match(text: str, known_norm: dict[str, str]) -> str | None:
    """Find the most specific known project appearing as a token in text."""
    low = text.lower()
    # First: "owner/repo" slug → last component.
    m = re.search(r"([A-Za-z0-9][\w.-]*)/([A-Za-z0-9][\w.-]+)", text)
    if m:
        tail = _normalize_token(m.group(2))
        if tail in known_norm:
            return known_norm[tail]
    best: tuple[int, str] | None = None  # (length, canonical)
    for tok in _PROJECT_TOKEN_RE.findall(low):
        key = _normalize_token(tok)
        if key in _PROJECT_STOPWORDS:
            continue
        canonical = known_norm.get(key)
        if canonical and (best is None or len(key) > best[0]):
            best = (len(key), canonical)
    return best[1] if best else None


def _canonical_project_for(
    entry: dict, known_norm: dict[str, str]
) -> str | None:
    """Attribute a snapshot project entry to a known canonical project."""
    # Check the entry name first — it is the strongest direct signal.
    hit = _best_project_match(entry.get("name", ""), known_norm)
    if hit:
        return hit
    for t in entry.get("titles", []):
        for field in ("title", "wm_class"):
            val = t.get(field, "")
            if not val:
                continue
            hit = _best_project_match(val, known_norm)
            if hit:
                return hit
    return None


def group_projects(
    projects: list[dict], known: list[str]
) -> tuple[list[dict], float]:
    """Collapse bucket-level projects into per-project aggregates.

    Returns (groups, unclassified_seconds). Each group has:
      name, seconds, hits, dominant_bucket, buckets (per-bucket seconds),
      titles (top combined), sample_count, is_known.
    """
    known_norm = {_normalize_token(k): k for k in known}
    groups: dict[str, dict] = {}
    unclassified = 0.0

    for p in projects:
        canon = _canonical_project_for(p, known_norm)
        secs = p.get("seconds", 0.0) or 0.0
        if canon is None:
            unclassified += secs
            continue
        g = groups.get(canon)
        if g is None:
            g = {
                "name": canon,
                "seconds": 0.0,
                "hits": 0,
                "buckets": {},
                "titles": [],
                "is_known": True,
            }
            groups[canon] = g
        g["seconds"] += secs
        g["hits"] += p.get("hits", 0)
        b = p.get("bucket", "other")
        g["buckets"][b] = g["buckets"].get(b, 0.0) + secs
        g["titles"].extend(p.get("titles", []))

    if unclassified > 0:
        groups["__unclassified__"] = {
            "name": "Unclassified",
            "seconds": unclassified,
            "hits": 0,
            "buckets": {},
            "titles": [],
            "is_known": False,
        }

    out: list[dict] = []
    for g in groups.values():
        if g["buckets"]:
            g["dominant_bucket"] = max(
                g["buckets"].items(), key=lambda kv: kv[1]
            )[0]
        else:
            g["dominant_bucket"] = "other"
        g["titles"].sort(
            key=lambda t: t.get("seconds", 0.0), reverse=True
        )
        g["titles"] = g["titles"][:8]
        out.append(g)
    out.sort(key=lambda g: g["seconds"], reverse=True)
    return out, unclassified


def _rounded_rect_path(cr, x, y, w, h, r):
    if w <= 0 or h <= 0:
        return
    if w < 2 * r:
        r = w / 2
    if h < 2 * r:
        r = h / 2
    if r < 0.5:
        cr.rectangle(x, y, w, h)
        return
    cr.new_path()
    cr.arc(x + r, y + r, r, math.pi, 3 * math.pi / 2)
    cr.arc(x + w - r, y + r, r, 3 * math.pi / 2, 0)
    cr.arc(x + w - r, y + h - r, r, 0, math.pi / 2)
    cr.arc(x + r, y + h - r, r, math.pi / 2, math.pi)
    cr.close_path()


class StackedBar(Gtk.DrawingArea):
    """Horizontal stacked summary of category proportions."""

    def __init__(self):
        super().__init__()
        self.set_content_height(12)
        self.set_hexpand(True)
        self._segments: list[tuple[tuple[int, int, int], float]] = []
        self.set_draw_func(self._draw)

    def set_segments(self, segments):
        self._segments = list(segments)
        self.queue_draw()

    def _draw(self, area, cr, width, height):
        radius = height / 2
        _rounded_rect_path(cr, 0, 0, width, height, radius)
        cr.clip()

        cr.set_source_rgba(0.5, 0.5, 0.5, 0.18)
        cr.rectangle(0, 0, width, height)
        cr.fill()

        total = sum(frac for _, frac in self._segments)
        if total <= 0:
            return
        x = 0.0
        for color, frac in self._segments:
            if frac <= 0:
                continue
            w = width * (frac / total)
            r, g, b = color
            cr.set_source_rgba(r / 255, g / 255, b / 255, 1.0)
            cr.rectangle(x, 0, w + 0.5, height)
            cr.fill()
            x += w


class MiniBar(Gtk.DrawingArea):
    """Thin progress indicator attached to each project row."""

    def __init__(self):
        super().__init__()
        self.set_content_height(5)
        self.set_hexpand(True)
        self._color = (154, 153, 150)
        self._frac = 0.0
        self.set_draw_func(self._draw)

    def set_data(self, color: tuple[int, int, int], frac: float):
        self._color = color
        self._frac = max(0.0, min(1.0, frac))
        self.queue_draw()

    def _draw(self, area, cr, width, height):
        radius = height / 2
        _rounded_rect_path(cr, 0, 0, width, height, radius)
        cr.set_source_rgba(0.5, 0.5, 0.5, 0.15)
        cr.fill()
        if self._frac <= 0:
            return
        fw = max(height, width * self._frac)
        _rounded_rect_path(cr, 0, 0, fw, height, radius)
        r, g, b = self._color
        cr.set_source_rgba(r / 255, g / 255, b / 255, 1.0)
        cr.fill()


