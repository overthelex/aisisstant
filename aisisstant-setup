class SplashScreen(Adw.Window):
    def __init__(self, app, on_done=None):
        super().__init__(
            application=app,
            title=APP_NAME,
            default_width=520,
            default_height=480,
            resizable=False,
            decorated=False,
            modal=True,
        )
        self._on_done = on_done
        self.set_content(_build_splash_content())
        GLib.timeout_add(3000, self._close_splash)
        click = Gtk.GestureClick()
        click.connect("released", lambda *_: self._close_splash())
        self.add_controller(click)

    def _close_splash(self):
        self.close()
        if self._on_done:
            GLib.idle_add(self._on_done)
        return False


