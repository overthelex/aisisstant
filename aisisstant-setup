    content = Gtk.Box(
        orientation=Gtk.Orientation.VERTICAL,
        spacing=0,
        halign=Gtk.Align.CENTER,
        valign=Gtk.Align.CENTER,
        margin_start=40,
        margin_end=40,
        margin_top=56,
        margin_bottom=56,
    )

    # Logo mark (light variant for dark splash bg). Fallback to emoji if missing.
    logo_path = _find_logo("logo-mark-light.svg")
