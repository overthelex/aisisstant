#!/usr/bin/env python3
"""Xsistant Setup Wizard & Settings UI.

GTK4/Adwaita application for initial setup and configuration management.
Launched automatically after package installation or from the app menu.
"""

import gi
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')

import grp
import json
import os
import subprocess
import sys
from pathlib import Path

from gi.repository import Adw, Gio, GLib, Gtk

APP_NAME = "Xsistant"
APP_ID = "com.aisisstant.Setup"
SERVICE_NAME = "aisisstant.service"
EXTENSION_UUID = "aisisstant-tracker@vovkes"
DB_CONTAINER = "aisisstant-db"
VERSION = "2026.04.16"

CONFIG_DIR = Path.home() / ".config" / "aisisstant"
CONFIG_FILE = CONFIG_DIR / "config.json"


def _find_logo(variant: str = "logo-mark-light.svg") -> str | None:
    """Locate a branding asset across dev and installed paths."""
    candidates = [
        Path(__file__).parent / "branding" / variant,
        Path("/usr/share/aisisstant/branding") / variant,
        Path.home() / "aisisstant" / "branding" / variant,
    ]
    for p in candidates:
        if p.exists():
            return str(p)
    return None


# ---------------------------------------------------------------------------
# System checks
# ---------------------------------------------------------------------------

def is_in_input_group() -> bool:
    try:
        input_gid = grp.getgrnam("input").gr_gid
        return input_gid in os.getgroups()
    except KeyError:
        return False


def add_to_input_group() -> bool:
    try:
        result = subprocess.run(
            ["pkexec", "usermod", "-aG", "input", os.getlogin()],
            capture_output=True, text=True, timeout=60,
        )
        return result.returncode == 0
    except Exception:
        return False


def is_accessibility_enabled() -> bool:
    try:
        result = subprocess.run(
            ["gsettings", "get", "org.gnome.desktop.interface", "toolkit-accessibility"],
            capture_output=True, text=True, timeout=5,
        )
        return result.stdout.strip() == "true"
    except Exception:
        return False


def enable_accessibility() -> bool:
    try:
        result = subprocess.run(
            ["gsettings", "set", "org.gnome.desktop.interface", "toolkit-accessibility", "true"],
            capture_output=True, text=True, timeout=5,
        )
        return result.returncode == 0
    except Exception:
        return False


def is_extension_enabled() -> bool:
    try:
        result = subprocess.run(
            ["gnome-extensions", "info", EXTENSION_UUID],
            capture_output=True, text=True, timeout=5,
        )
        return "ENABLED" in result.stdout
    except Exception:
        return False


def enable_extension() -> bool:
    try:
        result = subprocess.run(
            ["gnome-extensions", "enable", EXTENSION_UUID],
            capture_output=True, text=True, timeout=5,
        )
        return result.returncode == 0
    except Exception:
        return False


def is_docker_running() -> bool:
    try:
        result = subprocess.run(
            ["docker", "ps", "--filter", f"name={DB_CONTAINER}", "--format", "{{.Status}}"],
            capture_output=True, text=True, timeout=10,
        )
        return "Up" in result.stdout
    except Exception:
        return False


def start_docker_db() -> bool:
    try:
        compose_paths = [
            Path.home() / "aisisstant" / "docker-compose.yml",
            Path("/usr/share/aisisstant/docker-compose.yml"),
            Path(__file__).parent / "docker-compose.yml",
        ]
        compose_dir = None
        for p in compose_paths:
            if p.exists():
                compose_dir = str(p.parent)
                break
        if compose_dir is None:
            return False
        result = subprocess.run(
            ["docker", "compose", "up", "-d"],
            capture_output=True, text=True, timeout=60,
            cwd=compose_dir,
        )
        return result.returncode == 0
    except Exception:
        return False


def is_service_enabled() -> bool:
    try:
        result = subprocess.run(
            ["systemctl", "--user", "is-enabled", SERVICE_NAME],
            capture_output=True, text=True, timeout=5,
        )
        return result.stdout.strip() == "enabled"
    except Exception:
        return False


def is_service_running() -> bool:
    try:
        result = subprocess.run(
            ["systemctl", "--user", "is-active", SERVICE_NAME],
            capture_output=True, text=True, timeout=5,
        )
        return result.stdout.strip() == "active"
    except Exception:
        return False


def enable_and_start_service() -> bool:
    try:
        subprocess.run(
            ["systemctl", "--user", "daemon-reload"],
            capture_output=True, timeout=5,
        )
        subprocess.run(
            ["systemctl", "--user", "enable", SERVICE_NAME],
            capture_output=True, timeout=5,
        )
        result = subprocess.run(
            ["systemctl", "--user", "start", SERVICE_NAME],
            capture_output=True, timeout=10,
        )
        return result.returncode == 0
    except Exception:
        return False


def stop_service() -> bool:
    try:
        result = subprocess.run(
            ["systemctl", "--user", "stop", SERVICE_NAME],
            capture_output=True, timeout=5,
        )
        return result.returncode == 0
    except Exception:
        return False


def restart_service() -> bool:
    try:
        result = subprocess.run(
            ["systemctl", "--user", "restart", SERVICE_NAME],
            capture_output=True, timeout=10,
        )
        return result.returncode == 0
    except Exception:
        return False


def load_config() -> dict:
    if not CONFIG_FILE.exists():
        return {}
    try:
        with open(CONFIG_FILE) as f:
            return json.load(f)
    except Exception:
        return {}


def save_config(data: dict) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    try:
        with open(CONFIG_FILE, "w") as f:
            json.dump(data, f, indent=2)
    except Exception as e:
        print(f"Error saving config: {e}", file=sys.stderr)


def get_db_row_counts() -> dict:
    """Get row counts from the database for the status display."""
    try:
        result = subprocess.run(
            [
                "psql", "-h", "127.0.0.1", "-p", "5438",
                "-U", "aisisstant", "-d", "aisisstant",
                "-t", "-A", "-c",
                "SELECT json_build_object("
                "'input', (SELECT count(*) FROM input_activity),"
                "'windows', (SELECT count(*) FROM window_sessions),"
                "'scores', (SELECT count(*) FROM activity_scores),"
                "'mic', (SELECT count(*) FROM mic_activity),"
                "'idle', (SELECT count(*) FROM idle_events))",
            ],
            capture_output=True, text=True, timeout=5,
            env={**os.environ, "PGPASSWORD": "aisisstant_dev"},
        )
        if result.returncode == 0:
            return json.loads(result.stdout.strip())
    except Exception:
        pass
    return {}


